{
  "name": "iptv-monitoring",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\" \"npm run dev:ml\" --names \"NEXT,BACKEND,ML\" --prefix-colors \"blue,green,yellow\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:ml": "cd backend/ml-service && python -m uvicorn app.main:app --host 0.0.0.0 --port 8001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3",
    "@heroicons/react": "^2.2.0",
    "@mantine/core": "^8.1.3",
    "@mantine/hooks": "^8.1.3",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@tabler/icons-react": "^3.34.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.21",
    "chart.js": "^4.5.1",
    "cloudinary": "^2.7.0",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.0.10",
    "jose": "^6.0.11",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.564.0",
    "mongodb": "^7.0.0",
    "next": "^16.0.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.3",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.1.0",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.19"
  }
}