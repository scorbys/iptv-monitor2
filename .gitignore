# Environment files (keep .env.example but ignore .env with keys)
.env
.env.local
.env.production
.env.development

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Build outputs
/dist
/build
.next/
out/

# Temporary files
*.tmp
.cache/

# Lock files (optional - remove if you want to commit them)
# package-lock.json
# yarn.lock

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Claude
.claude/

# Nogic
.nogic/

# Unnecessary files
bash.exe.stackdump
tesis/

