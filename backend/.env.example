# ==================== REQUIRED ENVIRONMENT VARIABLES ====================
# Copy this to Railway Variables tab

# ==================== BASIC CONFIGURATION ====================
NODE_ENV=production
PORT=3001

# ==================== DATABASE ====================
# MongoDB Connection String
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.wnmnw.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ==================== AUTHENTICATION ====================
# Secret key for JWT tokens (use strong random string)
JWT_SECRET=your-very-secure-random-jwt-secret-key-here

# ==================== GOOGLE OAUTH ====================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ==================== TELEGRAM BOT ====================
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ==================== AI SERVICES ====================
# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# ==================== URL CONFIGURATION ====================
# Backend URL (Railway production URL)
BASE_URL=https://iptv-monitor-backend-production.up.railway.app

# Frontend URL (Vercel production URL)
FRONTEND_URL=https://iptv-monitor.vercel.app

# Domain for cookies (must match frontend)
COOKIE_DOMAIN=.vercel.app

# ==================== OPTIONAL CONFIGURATION ====================
# Telegram Bot Configuration (optional)
TELEGRAM_BOT_USERNAME=your_bot_username

# Feature Flags (optional)
USE_DUMMY_STATUS=true
ENABLE_TELEGRAM_BOT=true
ENABLE_GEMINI_AI=true

# ==================== SECURITY NOTES ====================
# 1. Never commit .env files to git
# 2. Use strong random values for secrets
# 3. Rotate credentials periodically
# 4. Use different values for production/development
# 5. Set IP whitelist in MongoDB Atlas
